<version xsi:noNamespaceSchemaLocation="classpath:com/runwaysdk/resources/xsd/version.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <doIt>
    <create>
       <mdRelationship name="net.geoprism.registry.geometry.JobHistoryGeometry" label="Job History Geometry" generateController="false" exported="false" publish="false"  generateSource="false">
        <parent cardinality="*" name="net.geoprism.registry.jobs.GPRJobHistory" method="JobHistory" />
        <child cardinality="*" name="net.geoprism.registry.geometry.GeometryTable" method="GeometryTable" />
      </mdRelationship>
      
      <mdBusiness name="net.geoprism.registry.JobHistoryTileCache">
        <attributes>
          <reference name="history" label="Job History" type="net.geoprism.registry.jobs.GPRJobHistory"  required="true"/>
          <integer name="x" label="X" required="true"/>
          <integer name="y" label="Y" required="true"/>
          <integer name="z" label="z" required="true"/>
          <blob name="tile" label="tile"/>          
        </attributes>
      </mdBusiness>
      
      <mdIndex type="net.geoprism.registry.JobHistoryTileCache" label="Job History Tile Cache" active="true" unique="true">
        <attribute name="history" indexOrder="0"/>
        <attribute name="x" indexOrder="1"/>
        <attribute name="y" indexOrder="2"/>
        <attribute name="z" indexOrder="3"/>
      </mdIndex>   
  
    </create>
    <permissions>  
      <role roleName="PUBLIC">
        <grant>
          <mdBusinessPermission type="net.geoprism.registry.JobHistoryTileCache">
            <operation name="ALL"/>
          </mdBusinessPermission>
        </grant>      
      </role>    
      <role roleName="geoprism.admin.Administrator">
        <grant>
          <mdBusinessPermission type="net.geoprism.registry.JobHistoryTileCache">
            <operation name="ALL"/>
          </mdBusinessPermission>
          <mdRelationshipPermission type="net.geoprism.registry.geometry.JobHistoryGeometry">
            <operation name="ALL"/>
          </mdRelationshipPermission>          
        </grant>
      </role>      
      <role roleName="cgr.RegistryMaintainer">
        <grant>
          <mdBusinessPermission type="net.geoprism.registry.JobHistoryTileCache">
            <operation name="ALL"/>
          </mdBusinessPermission>
          <mdBusinessPermission type="net.geoprism.registry.graph.BusinessType">
            <operation name="ALL" />
          </mdBusinessPermission>          
          <mdBusinessPermission type="net.geoprism.registry.graph.BusinessEdgeType">
            <operation name="ALL" />
          </mdBusinessPermission>          
          <mdRelationshipPermission type="net.geoprism.registry.geometry.JobHistoryGeometry">
            <operation name="ALL"/>
          </mdRelationshipPermission>          
        </grant>
      </role>
      <role roleName="cgr.RegistryContributor">
        <grant>
          <mdBusinessPermission type="net.geoprism.registry.JobHistoryTileCache">
            <operation name="ALL"/>
          </mdBusinessPermission>
          <mdRelationshipPermission type="net.geoprism.registry.geometry.JobHistoryGeometry">
            <operation name="ALL"/>
          </mdRelationshipPermission>          
          <mdBusinessPermission type="net.geoprism.registry.graph.BusinessType">
            <operation name="READ" />
            <operation name="READ_ALL_ATTRIBUTES" />
          </mdBusinessPermission>
          <mdBusinessPermission type="net.geoprism.registry.graph.BusinessEdgeType">
            <operation name="READ" />
            <operation name="READ_ALL_ATTRIBUTES" />
          </mdBusinessPermission>          
        </grant>
      </role>      
      <role roleName="cgr.APIConsumer">
        <grant>
          <mdBusinessPermission type="net.geoprism.registry.JobHistoryTileCache">
            <operation name="ALL"/>
          </mdBusinessPermission>
          <mdRelationshipPermission type="net.geoprism.registry.geometry.JobHistoryGeometry">
            <operation name="ALL"/>
          </mdRelationshipPermission>          
          <mdBusinessPermission type="net.geoprism.registry.graph.BusinessType">
            <operation name="READ" />
            <operation name="READ_ALL_ATTRIBUTES" />
          </mdBusinessPermission>
          <mdBusinessPermission type="net.geoprism.registry.graph.BusinessEdgeType">
            <operation name="READ" />
            <operation name="READ_ALL_ATTRIBUTES" />
          </mdBusinessPermission>
          
        </grant>
      </role>      
    </permissions>    
    
  </doIt>
  <undoIt>
    <delete>
      <object type="com.runwaysdk.system.metadata.MdBusiness" key="net.geoprism.registry.JobHistoryTileCache" />
      <object type="com.runwaysdk.system.metadata.MdRelationship" key="net.geoprism.registry.geometry.JobHistoryGeometry" />
    </delete>
  </undoIt>
   
</version>